[Unit]
Description=OpenCode Tailnet Router
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/opt/opencode-router
ExecStart=/usr/bin/node /opt/opencode-router/router/vps-opencode-router.js
Environment=OPENCODE_ROUTER_CACHE_DIR=/opt/opencode-router/cache
Restart=always
RestartSec=2
Environment=OPENCODE_ROUTER_HOST=127.0.0.1
Environment=OPENCODE_ROUTER_PORT=33102
Environment=OPENCODE_ROUTER_INSPECT_TIMEOUT_MS=8000
Environment=OPENCODE_ROUTER_WARM_TIMEOUT_MS=30000
Environment=OPENCODE_ROUTER_HTML_TIMEOUT_MS=8000
Environment=OPENCODE_ROUTER_RECOVERY_HTML_TIMEOUT_MS=15000
Environment=OPENCODE_ROUTER_BACKGROUND_SOFT_LIMIT=12
Environment=OPENCODE_ROUTER_MAX_BACKGROUND_QUEUE=20
Environment=OPENCODE_ROUTER_BACKGROUND_JOB_TTL_MS=45000
Environment=OPENCODE_ROUTER_HEAVY_BACKGROUND_SOFT_LIMIT=4
Environment=OPENCODE_ROUTER_PROMISE_AGE_SOFT_LIMIT_MS=10000
Environment=OPENCODE_ROUTER_WATCHER_SESSION_BUDGET=4
Environment=OPENCODE_ROUTER_WATCHER_SESSION_BUDGET_OVERLOAD=1
Environment=OPENCODE_ROUTER_ROOTS_REFRESH_TTL_MS=300000
Environment=OPENCODE_ROUTER_WATCHDOG_INTERVAL_MS=15000
Environment=OPENCODE_ROUTER_WATCHDOG_OVERLOAD_MS=60000

[Install]
WantedBy=multi-user.target
